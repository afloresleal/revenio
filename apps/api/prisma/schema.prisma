generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CALL_SCHEDULED
  CALL_IN_PROGRESS
  CALL_COMPLETED
  NO_ANSWER
  FAILED
}

model Lead {
  id        String       @id @default(uuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  name      String?
  phone     String
  source    String?
  status    LeadStatus   @default(NEW)
  attempts  CallAttempt[]
  events    Event[]
}

model CallAttempt {
  id         String    @id @default(uuid())
  leadId     String
  lead       Lead      @relation(fields: [leadId], references: [id])
  createdAt  DateTime  @default(now())
  status     String
  providerId String?
  controlUrl String?   @map("control_url")
  resultJson Json?
}

model Event {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  createdAt DateTime @default(now())
  type      String
  detail    Json?
}

// Dashboard Metrics - Voice Agent Performance
model CallMetric {
  id              String    @id @default(uuid())
  callId          String    @unique @map("call_id")
  phoneNumber     String    @map("phone_number")
  assistantId     String?   @map("assistant_id")
  transferNumber  String?   @map("transfer_number")
  twilioParentCallSid String? @map("twilio_parent_call_sid")
  twilioTransferCallSid String? @map("twilio_transfer_call_sid")
  transferStatus  String?   @map("transfer_status")
  
  startedAt       DateTime? @map("started_at")
  transferredAt   DateTime? @map("transferred_at")
  endedAt         DateTime? @map("ended_at")
  
  durationSec     Int?      @map("duration_sec")
  postTransferDurationSec Int? @map("post_transfer_duration_sec")
  endedReason     String?   @map("ended_reason")
  outcome         String?   // transfer_success, abandoned, completed, failed, in_progress
  sentiment       String?   // positive, neutral, negative
  
  // End-of-call-report data
  transcript      String?   @map("transcript")
  transferTranscript String? @map("transfer_transcript")
  fullTranscript  String?   @map("full_transcript")
  recordingUrl    String?   @map("recording_url")
  transferRecordingUrl String? @map("transfer_recording_url")
  transferRecordingDurationSec Int? @map("transfer_recording_duration_sec")
  recordingsJson  Json?     @map("recordings_json")
  cost            Decimal?  @map("cost") @db.Decimal(10, 4)
  
  inProgress      Boolean   @default(true) @map("in_progress")
  lastEventType   String?   @map("last_event_type")
  lastEventAt     DateTime? @map("last_event_at")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("call_metric")
  @@index([startedAt])
  @@index([outcome])
  @@index([sentiment])
  @@index([startedAt, outcome])
  @@index([sentiment, outcome])
}

model TwilioCallLink {
  id            String   @id @default(uuid())
  parentCallSid String   @unique @map("parent_call_sid")
  childCallSid  String?  @map("child_call_sid")
  vapiCallId    String   @map("vapi_call_id")
  leadId        String?  @map("lead_id")
  attemptId     String?  @map("attempt_id")
  childStatus   String?  @map("child_status")
  lastCallbackAt DateTime? @map("last_callback_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("twilio_call_link")
  @@index([vapiCallId])
  @@index([leadId])
  @@index([attemptId])
  @@index([childCallSid])
}
